{
  "name": "vault-chat-exporter",
  "displayName": "Vault Chat Exporter",
  "version": "0.1.0",
  "description": "Export AI chat conversations to your Obsidian vault",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://chat.openai.com/*",
      "https://chatgpt.com/*",
      "https://claude.ai/*",
      "https://gemini.google.com/*",
      "https://www.perplexity.ai/*",
      "http://127.0.0.1:27123/*",
      "http://localhost:27123/*",
      "https://127.0.0.1:27124/*"
    ],
    "permissions": [
      "storage",
      "activeTab",
      "tabs"
    ]
  }
}
